    {
      "parameters": {
        "jsCode": "// Simple transform for n8n: reads from items[0].json.content.parts[0].text\n// function camelCaseKey(k) {\n//   return String(k || '')\n//     .toLowerCase()\n//     .replace(/[^a-z0-9]+([a-z0-9])/g, (_, c) => c.toUpperCase())\n//     .replace(/[^a-z0-9]/g, '');\n// }\n\nfunction parseMaybeText(s) {\n  if (typeof s === 'object' && s !== null) return s;\n  if (typeof s !== 'string') throw new Error('Input not found or wrong type');\n  const first = s.indexOf('{');\n  const last = s.lastIndexOf('}');\n  const jsonText = first >= 0 && last >= 0 ? s.slice(first, last + 1) : s;\n  return JSON.parse(jsonText);\n}\n\ntry {\n  const rawText = $('Analyze document').first().json.content.parts[0].text;\n  const parsed = parseMaybeText(rawText);\n\n  const shiftKey = Object.keys(parsed).find(k => /distribution_of_daily_and_or_shift_hours/i.test(k));\n  const shift_hours = shiftKey && Array.isArray(parsed[shiftKey])\n    ? parsed[shiftKey].map(obj => {\n        const out = {};\n        for (const [k, v] of Object.entries(obj || {})) out[k] = v === '' ? null : v;\n      // out[camelCaseKey(k)]\n        return out;\n      })\n    : [];\n\n  const details = {};\n  for (const [k, v] of Object.entries(parsed)) {\n    if (k === shiftKey) continue;\n    details[k] = v;\n    // details[camelCaseKey(k)]\n  }\n\n  return [{ json: { shift_hours, details } }];\n} catch (err) {\n  return [{ json: { error: true, message: err.message } }];\n}\n"
      },
