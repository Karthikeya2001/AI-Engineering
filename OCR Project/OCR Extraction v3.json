        },
        "text": "Given the image of a receipt having multiple values and records, extract the data and give the output in a clean and structured json. Output should have all headers, list of items inside distribution of daily or shift hours, receipt number, and so on...  In the output, club all the items under 'item accounting for daily activities' using comma. Similarly club all the names of helpers extracted using comma.",
        "inputType": "binary",
        "binaryPropertyName": "=data",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1,
      "position": [
        192,
        464
      ],
      "id": "12d6bfee-d21e-4153-a084-cefbef72f082",
      "name": "Analyze document",
      "credentials": {
        "googlePalmApi": {
          "id": "pgvyD2cMyujoIXcT",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// n8n Function/Code node - simple explode of $input.first().json.shift_hours\ntry {\n  // read shift_hours from the first input item\n  const shift = (items[0] && items[0].json && $input.first().json.shift_hours) || [];\n\n  if (!Array.isArray(shift)) {\n    throw new Error('shift_hours is not an array at items[0].json.shift_hours');\n  }\n\n  if (shift.length === 0) {\n    // return an empty result (or an error item if you prefer)\n    return [{ json: { error: 'shift_hours is empty' } }];\n  }\n\n  // return one n8n item per shift entry (includes an optional _index)\n  return shift.map((entry, idx) => ({\n    json: { ...entry, _index: idx }\n  }));\n} catch (err) {\n  return [{ json: { error: true, message: err.message } }];\n}\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        864,
        368
      ],
      "id": "e7746b55-9890-447f-9e42-894001525b33",
      "name": "Shift hours format"
    },
    {
      "parameters": {
        "jsCode": "// n8n Function/Code node - flatten details into items\ntry {\n  const details = $input.first().json.details;\n\n  if (!details || typeof details !== 'object') {\n    throw new Error('details not found at items[0].json.details');\n  }\n\n  // Helper: normalize a value into a string\n  function normalize(val) {\n    if (val === null || val === undefined) return '';\n    if (Array.isArray(val)) {\n      return val.map(v => normalize(v)).join(', ');\n    }\n    if (typeof val === 'object') {\n      return Object.values(val)\n        .map(v => normalize(v))\n        .filter(v => v !== '')\n        .join(', ');\n    }\n    if (typeof val === 'string') {\n      return val.replace(/\\n/g, ', ').trim();\n    }\n    return String(val);\n  }\n\n  // Build output items\n  const output = Object.entries(details).map(([key, value], idx) => ({\n    json: {\n      key,\n      value: normalize(value),\n      _index: idx\n    }\n  }));\n\n  return output;\n} catch (err) {\n  return [{ json: { error: true, message: err.message } }];\n}\n"
      },
